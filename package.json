{
    "name": "n8n-nodes-okrunit",
    "version": "0.9.2",
    "description": "n8n community node for OKRunit human-in-the-loop approval gateway",
    "license": "MIT",
    "homepage": "https://okrunit.com/docs/integrations/n8n",
    "keywords": [
        "n8n-community-node-package",
        "n8n",
        "okrunit",
        "approval",
        "human-in-the-loop"
    ],
    "author": {
        "name": "Nathaniel",
        "email": "stoddard.nathaniel@yahoo.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Chain-React-Org/n8n-nodes-okrunit.git"
    },
   "scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "npm run build"
	},
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": false,
        "credentials": [
            "dist/credentials/OKRunitApi.credentials.js",
            "dist/credentials/OKRunitOAuth2Api.credentials.js"
        ],
        "nodes": [
            "dist/nodes/OKRunit/OKRunit.node.js",
            "dist/nodes/OKRunit/OkrunitTrigger.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "eslint": "9.32.0",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    }
}
